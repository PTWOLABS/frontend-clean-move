      "fieldGap": "16px",
      "labelSpacing": "8px",
      "footerActions": "sticky when forms are long"
    }
  },
  "components": {
    "button": {
      "base": {
        "height": "44px",
        "paddingX": "18px",
        "radius": "999px",
        "fontSize": "14px",
        "fontWeight": 600,
        "transition": "180ms ease"
      },
      "variants": {
        "primary": {
          "background": "primary",
          "foreground": "primaryForeground",
          "hover": "primaryHover",
          "active": "primaryActive"
        },
        "secondary": {
          "background": "accentSoft",
          "foreground": "graphite",
          "hover": "#E6D5AA"
        },
        "outline": {
          "background": "transparent",
          "foreground": "foreground",
          "border": "border",
          "hoverBackground": "surfaceMuted"
        },
        "ghost": {
          "background": "transparent",
          "foreground": "mutedForeground",
          "hoverBackground": "surfaceMuted"
        },
        "destructive": {
          "background": "danger",
          "foreground": "#FFFFFF",
          "hover": "#9F3E31"
        }
      }
    },
    "input": {
      "height": "44px",
      "background": "surface",
      "foreground": "foreground",
      "border": "border",
      "radius": "12px",
      "placeholder": "mutedForeground",
      "focusBorder": "primary",
      "focusRing": "focusRing"
    },
    "card": {
      "background": "surface",
      "border": "borderSubtle",
      "radius": "20px",
      "shadow": "card",
      "padding": "24px"
    },
    "badge": {
      "height": "24px",
      "radius": "999px",
      "paddingX": "10px",
      "fontSize": "12px",
      "fontWeight": 600
    },
    "table": {
      "background": "surface",
      "headerBackground": "surfaceMuted",
      "border": "borderSubtle",
      "rowHover": "surfaceElevated",
      "radius": "16px"
    },
    "modal": {
      "background": "surface",
      "radius": "24px",
      "shadow": "modal",
      "overlay": "rgba(6, 20, 17, 0.48)"
    },
    "toast": {
      "background": "surface",
      "border": "border",
      "radius": "16px",
      "shadow": "md"
    },
    "calendar": {
      "background": "surface",
      "border": "borderSubtle",
      "todayBackground": "accentSoft",
      "selectedBackground": "primary",
      "selectedForeground": "primaryForeground",
      "eventRadius": "10px",
      "eventBackground": "surfaceElevated",
      "eventBorder": "borderSubtle"
    },
    "kpiCard": {
      "background": "surface",
      "border": "borderSubtle",
      "radius": "20px",
      "padding": "20px",
      "titleColor": "mutedForeground",
      "valueColor": "foreground",
      "trendPositive": "success",
      "trendNegative": "danger"
    },
    "emptyState": {
